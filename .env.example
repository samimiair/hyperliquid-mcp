# Hyperliquid MCP Server — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── REQUIRED ──
# Your wallet private key (64 hex characters, with or without 0x)
HYPERLIQUID_PRIVATE_KEY=your_private_key_here

# Your wallet address (0x...)
HYPERLIQUID_ACCOUNT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# ── OPTIONAL ──
# API Wallet address for Agent Mode (leave same as account_address if not using API wallet)
HYPERLIQUID_API_WALLET=

# Set to "true" for testnet, "false" or leave empty for mainnet
HYPERLIQUID_TESTNET=false
